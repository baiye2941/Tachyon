{
  "name": "tachyon-frontend",
  "version": "0.1.1-0",
  "private": true,
  "packageManager": "bun@1.x",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "bun --bun vite build",
    "analyze": "ANALYZE=true bun run build",
    "preview": "bun --bun vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint src/ --max-warnings 0",
    "lint:colors": "bun run scripts/lint-color-hardcode.ts",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@motionone/solid": "^10.16.4",
    "@tanstack/solid-virtual": "^3.13.6",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "solid-i18n": "^1.1.0",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@phosphor-icons/core": "^2.1.1",
    "@playwright/test": "^1.61.0",
    "@solidjs/testing-library": "^0.8.10",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-plugin-solid": "^0.14.5",
    "jsdom": "^29.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "10.4.6",
    "storybook-solidjs-vite": "^10.4.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
