{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/main/crates/tauri-config-schema/schema.json",
  "productName": "Tachyon",
  "version": "0.1.2",
  "identifier": "com.tachyon.app",
  "build": {
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": {
      "script": "bun run dev",
      "cwd": "../../frontend"
    },
    "beforeBuildCommand": {
      "script": "bun run build",
      "cwd": "../../frontend"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tachyon",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "devtools": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/baiye2941/ai-model-downloader/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwMzQ2RUY1NzExMzc1MUMKUldRY2RSTng5VzQwNElaZ0dnL2N4dmhyUnkzSC83aVUyU2FnQzNSS25ENFFDUnYvS1YvSkdIcDgK",
      "dialog": true
    }
  }
}
