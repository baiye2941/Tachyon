{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Tachyon 主窗口默认权限: core 窗口控制; dialog open/save; notification 系统通知; 剪贴板仅后端 ClipboardWatcher 读取(无 clipboard-manager:allow-read-text, SEC-009); 无 shell",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-is-maximized",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "dialog:allow-save",
    "notification:default"
  ]
}
